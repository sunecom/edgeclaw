  },
  "硬件": {
    "型号": "LigoWave NFT-2ac",
    "CPU": "Qualcomm Atheros QCA956X (MIPS 74Kc, 大端序)",
    "RAM": "61MB",
    "系统": "Linux 4.4.14 (BusyBox)",
    "约束": "根分区 9.8MB 只读，/tmp 61MB，无动态库需静态链接"
