  },
  "服务器端口": {
    "3001": "Web 控制台 / HTTP API / WebSocket",
    "18883": "MQTT 状态汇报（路由器→服务器）",
    "19999": "CMD 实时指令下发 + 结果回传（双向）"
  },
  "多节点设计": {
    "设备ID": "自动从 hostname 生成（如 ec-17A42C）",
    "助记名称": "hostname 全名（如 NFT-2ac-17A42C），前台可手动设置别名",
    "数据存储": "服务器端 Map<deviceId, {mqttSocket, cmdSocket, alias}>",
    "代码通用": "一台设备无需改代码"
  },
  "可用指令": [
    "ping → 直接返回 pong",
    "net_status → ifconfig",
    "refresh_load → cat /proc/loadavg",
    "scan_wifi → iwinfo",
    "reboot → 重启路由器",
    "sys_info → cat /proc/cpuinfo + uptime + free -m",
    "signal_quality → iwconfig ath0 + ath1"
  ],
  "路由器客户端": {
    "源码": "monitor_edgeclaw.c",
