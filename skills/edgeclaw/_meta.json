    "编译器": "mips-linux-gnu-gcc",
    "编译参数": "-static -o public/monitor_edgeclaw monitor_edgeclaw.c",
    "产物特征": "ELF 32-bit MSB, MIPS MIPS32 rel2, statically linked",
    "产物大小": "~693KB（Go 版 8.6MB 会 OOM）",
    "部署方式": "路由器执行 /etc/rc.local 自动下载",
